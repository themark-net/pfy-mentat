# Pins for LiteLLM + Ollama cage smoke (T-0012 / T-0021 MVP)
SMOKE_ID=litellm-ollama
SMOKE_DATE=2026-07-12
LITELLM_PIP_SPEC=litellm>=1.40.0
# Smallest local coding model on this host at smoke design time (~0.78 GB)
LITELLM_SMOKE_MODEL=deepseek-coder:latest
# Host Ollama (loopback) and user-space gateway published for Docker
OLLAMA_HOST_LOOPBACK=http://127.0.0.1:11434
OLLAMA_GATEWAY_PORT=11435
# From inside agent-cage (via policy coding-agent-local + host-gateway)
OLLAMA_HOST_FROM_CAGE=http://host.docker.internal:11435
OPENAI_BASE_URL_FROM_CAGE=http://host.docker.internal:11435/v1
DEPLOY_PROFILE=local-only
MAX_OLLAMA_PULL_DISK_GB=150
# Do not pull if model already local; pulls allowed only under MAX_OLLAMA_PULL_DISK_GB
AGENT_CAGE_POLICY=coding-agent-local
