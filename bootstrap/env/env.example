# Copy to repo-root .env (gitignored):  make env-init
# Never commit real secrets.

# --- Deployment profile ---
# local-only | balanced | max-performance
DEPLOY_PROFILE=balanced

# --- Agent cage ---
AGENTCAGE_DIR=${HOME}/.agentcage

# --- Grok / xAI (secret) ---
# XAI_API_KEY=

# --- Local inference ---
OLLAMA_HOST=http://127.0.0.1:11434
# From inside Docker/cage, host Ollama often needs:
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1

# --- LiteLLM (optional) ---
# LITELLM_MASTER_KEY=
# LITELLM_CONFIG=config/litellm/config.yaml

# --- Optional cloud fallbacks (secret) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Write-guard MCP (planned) ---
WRITE_GUARD_MODE=audit
WRITE_GUARD_ROOTS=/workspace

# --- Optional ---
# HF_TOKEN=
# GITHUB_TOKEN=
