# Copy to repo-root .env (gitignored):  make env-init
# Never commit real secrets.

# --- Deployment profile ---
# local-only | balanced | max-performance
DEPLOY_PROFILE=balanced

# --- Agent cage ---
AGENTCAGE_DIR=${HOME}/.agentcage

# --- Grok Build auth ---
# Primary (interactive / subscription): browser or device OIDC → ~/.grok/auth.json
#   Host:  grok login
#   Cage:  make cage-grok-auth-import   # copies auth.json into ~/.agentcage/grok-home/
#      or: inside cage → grok login --device-auth
# Optional API key fallback (console.x.ai) — only if no auth.json session:
# XAI_API_KEY=

# --- Local inference ---
OLLAMA_HOST=http://127.0.0.1:11434
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# From inside agent-cage (see examples/litellm-ollama/host-ollama-gateway.sh):
# OLLAMA_HOST=http://host.docker.internal:11435
# OPENAI_BASE_URL=http://host.docker.internal:11435/v1
# LITELLM_SMOKE_MODEL=deepseek-coder:latest

# --- LiteLLM (T-0012 profiles) ---
# LITELLM_CONFIG=config/litellm/local-only.yaml   # or balanced.yaml / max-performance.yaml
# OLLAMA_API_BASE=http://127.0.0.1:11434          # host; cage: http://host.docker.internal:11435
# LITELLM_CLOUD_MODEL=xai/grok-3                  # balanced / max-performance
# LITELLM_MASTER_KEY=                             # only if exposing a shared proxy

# --- Optional cloud fallbacks (secret) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Write-guard MCP (planned) ---
WRITE_GUARD_MODE=audit
WRITE_GUARD_ROOTS=/workspace

# --- Optional ---
# HF_TOKEN=
# GITHUB_TOKEN=
