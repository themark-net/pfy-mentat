# Non-secret profile defaults — local bulk + cloud for hard tasks
DEPLOY_PROFILE=balanced
OLLAMA_HOST=http://127.0.0.1:11434
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# LiteLLM: set OLLAMA_API_BASE to same host (no /v1) for ollama/* models
OLLAMA_API_BASE=http://127.0.0.1:11434
LITELLM_CONFIG=config/litellm/balanced.yaml
LITELLM_CLOUD_MODEL=xai/grok-3
LITELLM_SMOKE_MODEL=deepseek-coder:latest
# Cloud keys come from .env only (XAI_API_KEY, etc.)
WRITE_GUARD_MODE=audit
WRITE_GUARD_ROOTS=/workspace
