# Non-secret profile defaults — cloud-first, local optional fallback
DEPLOY_PROFILE=max-performance
OLLAMA_HOST=http://127.0.0.1:11434
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_API_BASE=http://127.0.0.1:11434
LITELLM_CONFIG=config/litellm/max-performance.yaml
LITELLM_CLOUD_MODEL=xai/grok-3
LITELLM_SMOKE_MODEL=deepseek-coder:latest
# Prefer routing heavy reasoning to cloud via LiteLLM (see deployment-profiles.md)
# Requires XAI_API_KEY (or equivalent) in .env
WRITE_GUARD_MODE=audit
WRITE_GUARD_ROOTS=/workspace
