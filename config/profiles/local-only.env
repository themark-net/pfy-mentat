# Non-secret profile defaults — local ONLY
DEPLOY_PROFILE=local-only
# Prefer local OpenAI-compatible endpoint (Ollama, llama.cpp, etc.)
OLLAMA_HOST=http://127.0.0.1:11434
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# No cloud required; do not fail init if XAI_API_KEY missing
WRITE_GUARD_MODE=enforce
WRITE_GUARD_ROOTS=/workspace
