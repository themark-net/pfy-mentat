# Non-secret profile defaults — local ONLY
DEPLOY_PROFILE=local-only
# Prefer local OpenAI-compatible endpoint (Ollama, llama.cpp, etc.)
# Host processes:
OLLAMA_HOST=http://127.0.0.1:11434
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# Inside agent-cage (after host-ollama-gateway + coding-agent-local policy):
#   OLLAMA_HOST=http://host.docker.internal:11435
#   OPENAI_BASE_URL=http://host.docker.internal:11435/v1
# Smoke model (override if you prefer another local coding tag):
LITELLM_SMOKE_MODEL=deepseek-coder:latest
LITELLM_CONFIG=config/litellm/local-only.yaml
# No cloud required; do not fail init if XAI_API_KEY missing
WRITE_GUARD_MODE=enforce
WRITE_GUARD_ROOTS=/workspace
